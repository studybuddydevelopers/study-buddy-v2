// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"  // or "prisma-client", depending
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // no url, no directUrl
}

model TestItem {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
}

